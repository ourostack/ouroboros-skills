{
  "name": "desk",
  "version": "1.7.14",
  "description": "A quiet workspace substrate for long-running engineering agents: tracks, tasks, friction notes, lessons, lifecycle skills, and an MCP server for desk CRUD plus search. Ships a default 'worker' agent that makes the plugin standalone-functional; overlays (corporate, autonomous, personal-coding) layer their own agents on top.",
  "author": {
    "name": "ourostack",
    "url": "https://github.com/ourostack/ouroboros-skills"
  },
  "homepage": "https://github.com/ourostack/ouroboros-skills/tree/main/plugins/desk",
  "repository": "https://github.com/ourostack/ouroboros-skills",
  "license": "MIT",
  "keywords": [
    "agent-workspace",
    "tasks",
    "engineering",
    "mcp",
    "long-running-agent"
  ],
  "agents": "./agents/",
  "skills": "./skills/",
  "mcpServers": "./.mcp.json",
  "activation": {
    "copilot": {
      "targets": {
        "desk:worker": {
          "default": true,
          "source": "agents/worker.agent.md",
          "activationSurface": "root-plugin-agent"
        }
      },
      "dependencies": {
        "work-suite": {
          "path": "../work-suite",
          "version": "1.5.4",
          "resolution": "flattened",
          "bundleMetadata": "plugins/desk/activation/copilot-root.flattened-bundle.json"
        }
      },
      "manualSetupSteps": []
    }
  }
}
