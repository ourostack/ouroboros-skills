    name: desk MCP tests

    # Runs the desk MCP server test suite through the coverage gate
    # (plugins/desk/mcp `npm run test:coverage`).
    # Skill-manifest validation lives in validate-skills.yml and does NOT exercise
    # the MCP code, so without this job desk-core changes can merge untested.
